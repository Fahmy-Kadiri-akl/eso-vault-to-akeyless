# Copy to .env and fill in values: cp .env.example .env && chmod 600 .env

# --- Vault ---
VAULT_ADDR=http://vault.vault.svc.cluster.local:8200
VAULT_TOKEN=your-vault-token

# --- Akeyless ---
AKEYLESS_API=https://api.akeyless.io
AKEYLESS_ACCESS_ID=p-xxxxxxxxxxxx
AKEYLESS_GATEWAY_URL=https://your-gateway.example.com

# --- Demo app secrets (used by seed-vault-secrets.sh) ---
DB_HOST=postgres.demo.svc.cluster.local
DB_PORT=5432
DB_USERNAME=demo_user
DB_PASSWORD=changeme
DB_NAME=demo_db

STRIPE_KEY=sk_test_changeme
SENDGRID_KEY=SG.changeme
DATADOG_API_KEY=dd-changeme

APP_ENV=production
LOG_LEVEL=info
FEATURE_FLAGS=enable_v2_api,dark_mode
